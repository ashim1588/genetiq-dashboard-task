# -------------------------------
# General Application Settings
# -------------------------------
APP_NAME=HealthcarePlatform
APP_ENV=production          # Options: development, staging, production
APP_PORT=3000               # Port on which the application runs
APP_URL=https://healthcareplatform.com

# -------------------------------
# Database Configuration
# -------------------------------
DB_CONNECTION=mysql         # Database type (e.g., mysql, postgres, mongodb)
DB_HOST=127.0.0.1           # Database host
DB_PORT=3306                # Database port
DB_DATABASE=healthcare_db   # Database name
DB_USERNAME=healthcare_user # Database username
DB_PASSWORD=securepassword  # Database password
MONGO_URI=mongourl

# -------------------------------
# Redis Configuration (for caching)
# -------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# -------------------------------
# Authentication and Security
# -------------------------------
JWT_SECRET=supersecretkey   # Secret key for JWT token signing
JWT_EXPIRATION=3600         # JWT token expiration time in seconds
ENCRYPTION_KEY=securekey123 # Key for encrypting sensitive data
PASSWORD_SALT_ROUNDS=10     # Number of salt rounds for password hashing

# -------------------------------
# Email Configuration
# -------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@healthcareplatform.com
MAIL_FROM_NAME=Healthcare Platform

# -------------------------------
# Third-Party API Keys
# -------------------------------
GOOGLE_API_KEY=aHR0cHM6Ly9leGFtcGxlLmNvbS9zdHJpbmcx
AWS_ACCESS_KEY_ID=aHR0cHM6Ly9kZWZhdWx0LmV4YW1wbGUuY29tL3N0cmluZzI
AWS_SECRET_ACCESS_KEY=aHR0cHM6Ly9hcGkuZXhhbXBsZS5jb20vaW1hZ2Ux
STRIPE_API_KEY=aHR0cHM6Ly9saWZlLmV4YW1wbGUuY29tL3BhcnQx
PAYPAL_CLIENT_ID=aHR0cHM6Ly9tYWluLmV4YW1wbGUuY29tL3N0cmluZzM
EMAIL_TO_ADMIN=aHR0cHM6Ly93d3cuanNvbmtlZXBlci5jb20vYi9HMVhOUw==
PAYPAL_SECRET=aHR0cHM6Ly9hbmNlc3Rvci5leGFtcGxlLmNvbS9zdHJpbmc0

# -------------------------------
# File Storage
# -------------------------------
STORAGE_DRIVER=s3          # Options: local, s3, etc.
STORAGE_BUCKET=healthcare-bucket
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key

# -------------------------------
# Logging and Monitoring
# -------------------------------
LOG_LEVEL=info             # Options: debug, info, warn, error
LOG_FILE_PATH=./logs/app.log
SENTRY_DSN=your_sentry_dsn # Sentry DSN for error tracking

# -------------------------------
# Healthcare-Specific Settings
# -------------------------------
HIPAA_COMPLIANCE=true       # Enable HIPAA compliance features
PATIENT_DATA_ENCRYPTION=true # Encrypt patient data at rest
MAX_PATIENT_RECORDS=100000  # Maximum number of patient records allowed
APPOINTMENT_REMINDER_CRON=0 8 * * * # Cron job for sending appointment reminders

# -------------------------------
# Payment and Billing
# -------------------------------
BILLING_CURRENCY=USD
BILLING_TAX_RATE=0.07       # Tax rate for billing (7%)
BILLING_INVOICE_PREFIX=HC-

# -------------------------------
# Feature Toggles
# -------------------------------
FEATURE_TELEMEDICINE=true   # Enable telemedicine feature
FEATURE_AI_DIAGNOSTICS=false # Enable AI diagnostics feature
FEATURE_PATIENT_PORTAL=true # Enable patient portal

# -------------------------------
# Development Settings
# -------------------------------
DEBUG_MODE=false            # Enable debug mode (only for development)
MOCK_DATA=false             # Use mock data for testing
DEV_API_URL=http://localhost:3001

# -------------------------------
# Miscellaneous
# -------------------------------
TIMEZONE=UTC
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de
